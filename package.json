{
  "name": "@enrichlayer/sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for Enrich Layer — company, person, and contact enrichment API with Clearbit-compatible drop-in replacement",
  "license": "MIT",
  "author": "Enrich Layer <tools@enrichlayer.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/enrichlayer/sdk"
  },
  "homepage": "https://enrichlayer.com",
  "keywords": [
    "enrichlayer",
    "enrich-layer",
    "enrichment",
    "clearbit",
    "company-data",
    "person-data",
    "lead-enrichment",
    "data-enrichment",
    "api",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./compat": {
      "import": {
        "types": "./dist/esm/compat/index.d.ts",
        "default": "./dist/esm/compat/index.js"
      },
      "require": {
        "types": "./dist/cjs/compat/index.d.cts",
        "default": "./dist/cjs/compat/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/fix-cjs.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
